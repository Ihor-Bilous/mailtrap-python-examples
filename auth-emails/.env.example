# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret

# Mailtrap transactional API token (https://mailtrap.io → Sending → API Tokens)
MAILTRAP_API_TOKEN=your-mailtrap-api-token

# Sender identity (must be a verified domain in your Mailtrap account)
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=Auth Demo

# Base URL used to build verification and reset links in emails
BASE_URL=http://localhost:8000

# How long email tokens remain valid, in seconds (default: 3600 = 1 hour)
TOKEN_MAX_AGE_SECONDS=3600
